{
  "rules": {
    "porodica_cehic": {
      ".read": true,
      ".write": true,
      "items": { ".validate": "newData.isList() || newData.val() === null" },
      "history": { ".validate": "newData.isList() || newData.val() === null" },
      "receipts": { ".validate": "newData.isList() || newData.val() === null" },
      "savGoals": { ".validate": "newData.isList() || newData.val() === null" },
      "presence": { ".read": true, ".write": true },
      "lastUpdated": { ".validate": "newData.isNumber()" },
      "lastDevice": { ".validate": "newData.isString()" }
    },
    ".read": false,
    ".write": false
  }
}
